# Core application storage (required locally)
APPWRITE_ENDPOINT=
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
ENABLE_LOCAL_AUTOMATION_WORKER=false
# Internal debug/testing routes are disabled automatically in production.
ENABLE_INTERNAL_TOOLS=false
APPWRITE_DATABASE_ID=cfarm

# Optional overrides used only while provisioning self-hosted Appwrite.
LOCAL_APPWRITE_CONSOLE_EMAIL=
LOCAL_APPWRITE_CONSOLE_PASSWORD=

# One-time source project for `pnpm appwrite:clone-schema` (cloud → local).
# Only needed while cloning schema to a self-hosted instance; remove afterward.
# See docs/reference/local-appwrite.md.
SRC_APPWRITE_ENDPOINT=
SRC_APPWRITE_PROJECT_ID=
SRC_APPWRITE_API_KEY=
# Optional owner used by non-request maintenance scripts.
LUMENCLIP_SYSTEM_OWNER_ID=
# Explicit owner for the local stdio MCP server. Required when APPWRITE_ENDPOINT
# points to localhost so a cloud system owner cannot silently produce empty reads.
LUMENCLIP_MCP_OWNER_ID=
# Optional one-time assignee for records created before authentication.
LUMENCLIP_LEGACY_OWNER_ID=

# Slideshow and content generation (required for generation)
OPENROUTER_API_KEY=

# Optional integrations
APIFY_KEY=
APIFY_YOUTUBE_ACTOR=pintostudio/youtube-transcript-scraper
APIFY_REDDIT_ACTOR=trudax/reddit-scraper-lite
# Optional override. Small-batch X discovery defaults to this Actor in code.
APIFY_TWITTER_ACTOR=apidojo/twitter-scraper-lite
APIFY_TIKTOK_ACTOR=clockworks/tiktok-scraper
# Photo-post importer; defaults to maximedupre/tiktok-slideshow-downloader.
APIFY_TIKTOK_SLIDESHOW_ACTOR=
APIFY_INSTAGRAM_ACTOR=apify/instagram-scraper
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
FAL_KEY=
FAL_WHISPER_MODEL=fal-ai/whisper
ELEVENLABS_API_KEY=
# Paid talking-actor generation remains disabled unless exactly true.
ENABLE_UGC_AUTOMATION=false
DEEPL_KEY=
KIE_KEY=
PEXELS_KEY=
POSTFAST_API_KEY=
RENDI_API_KEY=
# Telegram reminders. BASE_URL must be the public HTTPS app origin so Telegram
# can reach the confirmation callback (for example https://app.example.com).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
BASE_URL=

# Test tooling (database-backed tests use APPWRITE_DATABASE_ID above)
RUN_LIVE=
