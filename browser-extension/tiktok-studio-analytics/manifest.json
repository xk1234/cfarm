{
  "manifest_version": 3,
  "name": "LumenClip TikTok Studio Analytics",
  "version": "1.2.0",
  "description": "Imports analytics from your logged-in TikTok Studio tab into LumenClip without copying TikTok cookies.",
  "permissions": ["storage", "tabs", "alarms"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "host_permissions": [
    "https://www.tiktok.com/*",
    "https://cfarm-eight.vercel.app/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.tiktok.com/tiktokstudio/analytics/*"],
      "js": ["capture-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.tiktok.com/tiktokstudio/analytics/*"],
      "js": ["capture-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://cfarm-eight.vercel.app/*",
        "http://localhost/*"
      ],
      "js": ["lumenclip-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "LumenClip TikTok Studio Analytics",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_popup": "popup.html"
  }
}
