{
  "name": "lumenclip",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "env:check": "node scripts/check-env.mjs",
    "appwrite:multitenancy": "node scripts/provision-multitenancy.mjs",
    "appwrite:settings": "node scripts/provision-settings.mjs",
    "appwrite:benchmarks": "node scripts/provision-benchmarks.mjs",
    "appwrite:analytics": "node scripts/provision-analytics.mjs",
    "appwrite:sync-shared": "node scripts/sync-function-shared.mjs",
    "appwrite:check-shared": "node scripts/sync-function-shared.mjs --check",
    "appwrite:x-automations": "node scripts/provision-x-automations.mjs",
    "appwrite:product-collections": "node scripts/provision-product-collections.mjs",
    "appwrite:media-library": "node scripts/provision-media-library.mjs",
    "benchmarks:import": "node scripts/import-reelfarm-benchmarks.mjs",
    "products:import": "node scripts/import-product-collections.mjs",
    "predev": "pnpm env:check",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:live": "RUN_LIVE=1 vitest run --config vitest.live.config.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:live": "E2E_MODE=live playwright test",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.44.0",
    "ag-charts-types": "^14.0.0",
    "ag-grid-community": "^36.0.0",
    "ag-grid-react": "^36.0.0",
    "ag-stack": "^36.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsoneditor": "^10.4.3",
    "jszip": "^3.10.1",
    "lucide-react": "^1.22.0",
    "luxon": "^3.7.2",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "node-appwrite": "^26.2.0",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^17.0.0",
    "react-loading-skeleton": "3.5.0",
    "react-spinners": "^0.17.0",
    "recharts": "^3.9.1",
    "server-only": "^0.0.1",
    "shadcn": "^4.12.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/jsoneditor": "^9.9.6",
    "@types/luxon": "^3.7.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
