{
  "name": "lumenclip",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "env:check": "node scripts/check-env.mjs",
    "appwrite:clone-schema": "node scripts/clone-appwrite-schema.mjs",
    "appwrite:consolidated-stores": "node scripts/provision-consolidated-stores.mjs",
    "appwrite:migrate-consolidated": "tsx scripts/migrate-consolidated-data.ts",
    "appwrite:scan-legacy-shapes": "tsx scripts/scan-legacy-shapes.ts",
    "appwrite:migrate-legacy-shapes": "NODE_OPTIONS='--conditions=react-server' tsx scripts/migrate-legacy-persisted-shapes.ts",
    "appwrite:local:setup": "node scripts/setup-local-appwrite.mjs",
    "appwrite:local:sync-automations": "node scripts/sync-local-automations.mjs",
    "appwrite:local:sync-reference": "node scripts/sync-local-reference-data.mjs",
    "appwrite:sync-shared": "node scripts/sync-function-shared.mjs",
    "appwrite:check-shared": "node scripts/sync-function-shared.mjs --check",
    "products:import": "node scripts/import-product-collections.mjs",
    "dev": "node scripts/dev-local.mjs",
    "dev:web": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:design-tokens": "node scripts/check-design-tokens.mjs",
    "test": "vitest run --configLoader runner",
    "test:live": "RUN_LIVE=1 vitest run --config vitest.live.config.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:live": "E2E_MODE=live playwright test",
    "mcp": "NODE_OPTIONS='--conditions=react-server' tsx scripts/lumenclip-mcp.ts",
    "mcp:docs": "tsx scripts/generate-mcp-docs.ts",
    "mcp:docs:check": "tsx scripts/generate-mcp-docs.ts --check",
    "mcp:tiktok": "NODE_OPTIONS='--conditions=react-server' tsx scripts/lumenclip-tiktok-mcp.ts",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fullcalendar/core": "6.1.21",
    "@fullcalendar/daygrid": "6.1.21",
    "@fullcalendar/interaction": "6.1.21",
    "@fullcalendar/react": "6.1.21",
    "@fullcalendar/timegrid": "6.1.21",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@tabler/icons-react": "^3.44.0",
    "ag-charts-types": "^14.0.0",
    "ag-grid-community": "^36.0.0",
    "ag-grid-react": "^36.0.0",
    "ag-stack": "^36.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "16.11.5",
    "fumadocs-mdx": "15.2.0",
    "fumadocs-ui": "16.11.5",
    "jsoneditor": "^10.4.3",
    "jszip": "^3.10.1",
    "luxon": "^3.7.2",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "node-appwrite": "^26.2.0",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^17.0.0",
    "react-icons": "^5.7.0",
    "react-loading-skeleton": "3.5.0",
    "react-spinners": "^0.17.0",
    "recharts": "^3.9.1",
    "server-only": "^0.0.1",
    "shadcn": "^4.12.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/jsoneditor": "^9.9.6",
    "@types/luxon": "^3.7.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
