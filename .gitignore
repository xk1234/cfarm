/data/**/*.aac
/data/**/*.aiff
/data/**/*.avif
/data/**/*.flac
/data/**/*.gif
/data/**/*.jpeg
/data/**/*.jpg
/data/**/*.m4a
/data/**/*.mkv
/data/**/*.mov
/data/**/*.mp3
/data/**/*.mp4
/data/**/*.ogg
/data/**/*.png
/data/**/*.wav
/data/**/*.webm
/data/**/*.webp

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# typescript
*.tsbuildinfo
next-env.d.ts
